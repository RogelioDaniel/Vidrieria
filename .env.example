DATABASE_URL=file:../db/custom.db

# Optional realtime service. Leave blank on Vercel to keep chat offline
# without repeated WebSocket errors. Point these to a secured Socket.IO host
# only after configuring private visitor rooms and an allowed origin.
NEXT_PUBLIC_SOCKET_URL=
NEXT_PUBLIC_SOCKET_PATH=/socket.io
NEXT_PUBLIC_SOCKET_DISABLED=false
